meta {
  name: change-password
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/users/change-password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "oldPassword": "{{oldPassword}}",
    "newPassword": "{{newPassword}}"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
